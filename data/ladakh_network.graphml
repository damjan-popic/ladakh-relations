aga</data><data key="node_category">Person</data><data key="node_degree">5</data><data key="node_presetTags" /><data key="node_description">Indian logician whose epistemological developments underpin Santarakshita’s synthesis.</data><data key="node_lat" /><data key="node_lon" /></node><node id="YOL_PER_0013"><data key="node_label">Dogen</data><data key="node_category">Person</data><data key="node_degree">0</data><data key="node_presetTags" /><data key="node_description">Japanese Zen philosopher used in comparative discussion.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PER_0018"><data key="node_label">Drikungpa Kyobpa Jigten Gönpo</data><data key="node_category">Person</data><data key="node_degree">6</data><data key="node_presetTags">kagyu</data><data key="node_description">Foundational Drikung Kagyu master and attributed author of the Inborn Union Mahamudra introduction.</data><data key="node_lat" /><data key="node_lon" /></node><node id="YOL_PER_0014"><data key="node_label">Drubten</data><data key="node_category">Person</data><data key="node_degree">1</data><data key="node_presetTags" /><data key="node_description">Yogin living with Gegen Khyentse at Manali.</data><data key="node_lat" /><data key="node_lon" /></node><node id="YOL_PER_0015"><data key="node_label">Drugchen Rimpoche</data><data key="node_category">Person</data><data key="node_degree">0</data><data key="node_presetTags" /><data key="node_description">Provisional abbot/leader connected to Hemis.</data><data key="node_lat" /><data key="node_lon" /></node><node id="YOL_PER_0016"><data key="node_label">Dudjom Rimpoche</data><data key="node_category">Person</data><data key="node_degree">8</data><data key="node_presetTags">kagyu; nyingma</data><data key="node_description">Nyingma teacher indexed.</data><data key="node_lat" /><data key="node_lon" /></node><node id="YOL_PER_0017"><data key="node_label">Dungsey Rimpoche</data><data key="node_category">Person</data><data key="node_d