ge_outcome" /><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e915" source="EXT_PER_0027" target="T_VAJRA"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">kagyu</data></edge><edge id="e916" source="EXT_PER_0027" target="C_MAHAMUDRA"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e917" source="EXT_PER_0027" target="YOL_PRA_0011"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">drukpa; kagyu; nyingma</data></edge><edge id="e918" source="EXT_PER_0027" target="P_MILAREPA"><data key="edge_type">meeting_visit</data><data key="edge_label">meeting / visit</data><data key="edge_date">11th–12th century</data><data key="edge_outcome">Served as Milarepa's close disciple, requested the life story, witnessed relic events, and later transmitted cycles and relic-related legacy to Gampopa.</data><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e919" source="EXT_PER_0027" target="P_GAMPOPA"><data key="edge_type">meeting_visit</data><data key="edge_label">meeting / visit</data><data key="edge_date">after Milarepa's death</data><data key="edge_outcome">Served as Milarepa's close disciple, requested the life story, witnessed relic events, and later transmitted cycles and relic-related legacy to Gampopa.</data><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e920" source="EXT_PER_0029" target="T_DRUKPA"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e921" source="EXT_PER_0029" target="T_KAGYU"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e922" source="EXT_PER_0029" target="T_VAJRA"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e923" source="EXT_PER_0029" target="YOL_PLA_0004"><data key="edge_type">meeting_visit</data><data key="edge_label">meeting / visit</data><data key="edge_date">1625/26 onward</data><data key="edge_outcome">Fled to and established himself in Bhutan, where he institutionalized the Bhutanese Drukpa school and state.</data><data key="edge_presetTags">drukpa; kagyu; nyingma</data></edge><edge id="e924" source="EXT_PER_0030" target="T_DRUKPA"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e925" source="EXT_PER_0030" target="T_KAGYU"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e926" source="EXT_PER_0030" target="YOL_PLA_0004"><data key="edge_type">meeting_visit</data><data key="edge_label">meeting / visit</data><data key="edge_date">1184–1251</data><data key="edge_outcome">Helped establish Drukpa religious institutions in Bhutan before the later northern/southern branch split.</data><data key="edge_presetTags">drukpa; kagyu; nyingma</data></edge><edge id="e927" source="EXT_PER_0031" target="T_DRUKPA"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e928" source="EXT_PER_0031" target="T_KAGYU"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e929" source="EXT_PER_0031" target="T_VAJRA"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e930" source="EXT_PER_0031" target="YOL_PLA_0004"><data key="edge_type">meeting_visit</data><data key="edge_label">meeting / visit</data><data key="edge_date">1455–1529</data><data key="edge_outcome">Extended the Drukpa presence in Bhutan and became a famed exemplar of antinomian yogic holiness.</data><data key="edge_presetTags">drukpa; kagyu; nyingma</data></edge><edge id="e931" source="EXT_PER_0032" target="YOL_TRA_0010"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">nyingma</data></edge><edge id="e932" source="EXT_PER_0032" target="YOL_PRD_0006"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">kagyu; nyingma</data></edge><edge id="e933" source="EXT_PER_0032" target="EXT_PRA_0043"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">nyingma</data></edge><edge id="e934" source="EXT_PER_0032" target="EXT_PER_0008"><data key="edge_type">meeting_visit</data><data key="edge_label">meeting / visit</data><data key="edge_date">1335</data><data key="edge_outcome">Welcomed Longchenpa at Yartö Khyam and transmitted the Vima Nyingthig lineage to him.</data><data key="edge_presetTags">drukpa; kagyu; nyingma</data></edge><edge id="e935" source="EXT_PER_0032" target="EXT_PLA_0019"><data key="edge_type">meeting_visit</data><data key="edge_label">meeting / visit</data><data key="edge_date">1335</data><data key="edge_outcome">Welcomed Longchenpa at Yartö Khyam and transmitted the Vima Nyingthig lineage to him.</data><data key="edge_presetTags">nyingma</data></edge><edge id="e936" source="EXT_PER_0033" target="YOL_PRD_0006"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">kagyu; nyingma</data></edge><edge id="e937" source="EXT_PER_0033" target="EXT_PRA_0044"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">nyingma</data></edge><edge id="e938" source="EXT_PER_0033" target="EXT_PRA_0043"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">nyingma</data></edge><edge id="e939" source="EXT_PER_0033" target="YOL_TRA_0010"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">nyingma</data></edge><edge id="e940" source="EXT_PER_0034" target="YOL_TRA_0010"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">nyingma</data></edge><edge id="e941" source="EXT_PER_0034" target="YOL_PRD_0006"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">kagyu; nyingma</data></edge><edge id="e942" source="EXT_PER_0034" target="EXT_PRA_0043"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">nyingma</data></edge><edge id="e943" source="EXT_PER_0034" target="YOL_PER_0056"><data key="edge_type">meeting_visit</data><data key="edge_label">meeting / visit</data><data key="edge_date">8th century</data><data key="edge_outcome">Associated with Padmasambhava in the early Great Perfection transmission and with the Vima Nyingthig inherited by Longchenpa.</data><data key="edge_presetTags">kagyu; nyingma</data></edge><edge id="e944" source="EXT_PER_0034" target="EXT_PER_0008"><data key="edge_type">meeting_visit</data><data key="edge_label">meeting / visit</data><data key="edge_date">later lineage transmission</data><data key="edge_outcome">Associated with Padmasambhava in the early Great Perfection transmission and with the Vima Nyingthig inherited by Longchenpa.</data><data key="edge_presetTags">drukpa; kagyu; nyingma</data></edge><edge id="e945" source="EXT_PER_0035" target="YOL_TRA_0010"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">nyingma</data></edge><edge id="e946" source="EXT_PER_0035" target="YOL_PRD_0006"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">kagyu; nyingma</data></edge><edge id="e947" source="EXT_PER_0035" target="YOL_PER_0056"><data key="edge_type">meeting_visit</data><data key="edge_label">meeting / visit</data><data key="edge_date">8th century Tibetan transmission era</data><data key="edge_outcome">Received and safeguarded Heart-Essence teachings later linked to Longchenpa’s lineage narratives.</data><data key="edge_presetTags">kagyu; nyingma</data></edge><edge id="e948" source="EXT_PER_0036" target="T_MADHYAMAKA"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">nyingma</data></edge><edge id="e949" source="EXT_PER_0036" target="P_NAGARJUNA"><data key="edge_type">meeting_visit</data><data key="edge_label">meeting / visit</data><data key="edge_date">classical Indian Buddhist period</data><data key="edge_outcome">Received Nagarjuna’s precepts and helped clarify the middle way.</data><data key="edge_presetTags">kagyu</data></edge><edge id="e950" source="EXT_PER_0037" target="T_MADHYAMAKA"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">nyingma</data></edge><edge id="e951" source="EXT_PER_0037" target="EXT_PRA_0039"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags" /></edge><edge id="e952" source="EXT_PER_0038" target="T_MADHYAMAKA"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">nyingma</data></edge><edge id="e953" source="EXT_PER_0038" target="EXT_PRA_0038"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags" /></edge><edge id="e954" source="EXP_001" target="PL_LADAKH"><data key="edge_type">explorer_link</data><data key="edge_label">related in explorer record</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e955" source="EXP_001" target="PL_KASHMIR"><data key="edge_type">explorer_link</data><data key="edge_label">related in explorer record</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">kagyu</data></edge><edge id="e956" source="EXP_002" target="ENT_PLA_EX_001"><data key="edge_type">explorer_link</data><data key="edge_label">related in explorer record</data><data key="edge_date" /><data key="edge_outcome" /><data 