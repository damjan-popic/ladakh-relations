ta><data key="node_category">Underpinning</data><data key="node_degree">22</data><data key="node_presetTags">nyingma</data><data key="node_description">Emptiness and middle-path framework.</data><data key="node_lat" /><data key="node_lon" /></node><node id="T_MAHAYANA"><data key="node_label">Mahayana</data><data key="node_category">Underpinning</data><data key="node_degree">24</data><data key="node_presetTags">kagyu</data><data key="node_description">Bodhisattva ethics, compassion, Prajnaparamita, and emptiness.</data><data key="node_lat" /><data key="node_lon" /></node><node id="T_VAJRA"><data key="node_label">Vajrayana</data><data key="node_category">Underpinning</data><data key="node_degree">41</data><data key="node_presetTags">kagyu</data><data key="node_description">Tantric practice system, including vows, guru, subtle-body yoga, and song.</data><data key="node_lat" /><data key="node_lon" /></node><node id="T_VINAYA"><data key="node_label">Vinaya / pratimoksha</data><data key="node_category">Underpinning</data><data key="node_degree">18</data><data key="node_presetTags">kagyu</data><data key="node_description">Monastic ethical discipline and vow system.</data><data key="node_lat" /><data key="node_lon" /></node><node id="T_YOGACARA"><data key="node_label">Yogacara</data><data key="node_category">Underpinning</data><data key="node_degree">10</data><data key="node_presetTags" /><data key="node_description">Mind-centered philosophical language harmonized with Tantra.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_TRA_0006"><data key="node_label">Yogacara-Madhyamaka</data><data key="node_category">Underpinning</data><data key="node_degree">8</data><data key="node_presetTags" /><data key="node_description">Synthesis of Yogacara, Madhyamaka, and Buddhist epistemology associated with Santarakshita and Kamalashila.</data><data key="node_lat" /><data key="node_lon" /></node><node id="YOL_PRD_0008"><data key="node_label">Bardo</data><data key="node_category">Underpinning</data><data key="node_degree">10</data><data key="node_presetTags">kagyu</data><data key="node_description">Intermediate state practice.</data><data key="node_lat" /><data key="node_lon" /></node><node id="C_BODHICITTA"><data key="node_label">Bodhicitta</data><data key="node_category">Underpinning</data><data key="node_degree">18</data><data key="node_presetTags">kagyu; nyingma</data><data key="node_description">Thought of enlightenment and compassionate exchange.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0014"><data key="node_label">Bodhisattva Path</data><data key="node_category">Underpinning</data><data key="node_degree">17</data><data key="node_presetTags">kagyu</data><data key="node_description">Structured cultivation of altruistic aspiration and conduct on the path to buddhahood.</data><data key="node_lat" /><data key="node_lon" /></node><node id="YOL_PRD_0002"><data key="node_label">Bodhisattva Vow</data><data key="node_category">Underpinning</data><data key="node_degree">2</data><data key="node_presetTags" /><data key="node_description">Vow to liberate beings before oneself.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0024"><data key="node_label">Buddha-nature</data><data key="node_category">Underpinning</data><data key="node_degree">9</data><data key="node_presetTags">kagyu; nyingma</data><data key="node_description">Innate potential or seed of enlightenment that Gampopa presents as the primary cause of buddhahood.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0012"><data key="node_label">Calm abiding / Shamatha</data><data key="node_category">Underpinning</data><data key="node_degree">2</data><data key="node_presetTags">kagyu</data><data key="node_description">Stabilizing meditation focused on mental stillness and concentration.</data><data key="node_lat" /><data key="node_lon" /></node><node id="YOL_PRA_0001"><data key="node_label">Calming the mind / Shamatha</data><data key="node_category">Underpinning</data><data key="node_degree">4</data><data key="node_presetTags">kagyu</data><data key="node_description">Calming/stabilizing meditation.</data><data key="node_lat" /><data key="node_lon" /></node><node id="C_CANDALI"><data key="node_label">Candali / mystic heat</data><data key="node_category">Underpinning</data><data key="node_degree">3</data><data key="node_presetTags">kagyu</data><data key="node_description">Subtle-body wisdom-fire invoked in death-yoga.</data><data key="node_lat" /><data key="node_lon" /></node><node id="YOL_PRD_0003"><data key="node_label">Chod</data><data key="node_category">Underpinning</data><data key="node_degree">13</data><data key="node_presetTags" /><data key="node_description">Practice associated with Machig Labdron and cemeteries.</data><data key="node_lat" /><data key="node_lon" /></node><node id="YOL_PRD_0004"><data key="node_label">Clear Light</data><data key="node_category">Underpinning</data><data key="node_degree">12</data><data key="node_presetTags">kagyu; nyingma</data><data key="node_description">Practice/doctrine of luminosity.</data><data key="node_lat" /><data key="node_lon" /></node><node id="C_CONTENTMENT"><data key="node_label">Contentment / fewness of wishes</data><data key="node_category">Underpinning</data><data key="node_degree">2</data><data key="node_presetTags">kagyu</data><data key="node_description">Ascetic sufficiency against worldly desire.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0003"><data key="node_label">Death meditation</data><data key="node_category">Underpinning</data><data key="node_degree">0</data><data key="node_presetTags" /><data key="node_description">Meditative cultivation of awareness of mortality.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0001"><data key="node_label">Deity yoga</data><data key="node_category">Underpinning</data><data key="node_degree">8</data><data key="node_presetTags">kagyu; nyingma</data><data key="node_description">Tantric practice of identifying with and visualizing a deity.</data><data key="node_lat" /><data key="node_lon" /></node><node id="YOL_PRD_0005"><data key="node_label">Dorje Trollo</data><data key="node_category">Underpinning</data><data key="node_degree">2</data><data key="node_presetTags" /><data key="node_description">Meditational form/practice of Guru Rimpoche associated with Khamtag Rimpoche.</data><data key="node_lat" /><data key="node_lon" /></node><node id="YOL_PRA_0002"><data key="node_label">Dream Yoga</data><data key="node_category">Underpinning</data><data key="node_degree">9</data><data key="node_presetTags">kagyu; nyingma</data><data key="node_description">Practice for seeing waking/dream experience as dream-like.</data><data key="node_lat" /><data key="node_lon" /></node><node id="YOL_PRD_0006"><data key="node_label">Dzogchen</data><data key="node_category">Underpinning</data><data key="node_degree">38</data><data key="node_presetTags">kagyu; nyingma</data><data key="node_description">Great Perfection (Dzogchen) teaching, including Longchenpa’s nature-of-mind and dharmadhatu presentation.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0032"><data key="node_label">Five Paths</data><data key="node_category">Underpinning</data><data key="node_degree">4</data><data key="node_presetTags">kagyu</data><data key="node_description">The graded bodhisattva paths of accumulation, preparation, insight, meditation, and perfection.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0016"><data key="node_label">Four Persuasions</data><data key="node_category">Underpinning</data><data key="node_degree">6</data><data key="node_presetTags" /><data key="node_description">Set of four modes for maturing others that concludes the bodhisattva presentation.</data><data key="node_lat" /><data key="node_lon" /></node><node id="YOL_PRD_0007"><data key="node_label">Fruit meditation</data><data key="node_category">Underpinning</data><data key="node_degree">3</data><data key="node_presetTags" /><data key="node_description">Practice from the standpoint of already-present fruit.</data><data key="node_lat" /><data key="node_lon" /></node><node id="C_GURU"><data key="node_label">Guru / lama</data><data key="node_category">Underpinning</data><data key="node_degree">4</data><data key="node_presetTags">kagyu</data><data key="node_description">The teacher as spiritual catalyst and object of devotion.</data><data key="node_lat" /><data key="node_lon" /></node><node id="YOL_PRA_0003"><data key="node_label">Guru yoga</data><data key="node_category">Underpinning</data><data key="node_degree">3</data><data key="node_presetTags">kagyu</data><data key="node_description">Practice of identifying teacher with Buddha/lineage.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0013"><data key="node_label">Higher insight / Vipashyana</data><data key="node_category">Underpinning</data><data key="node_degree">2</data><data key="node_presetTags">kagyu</data><data key="node_description">Analytical insight meditation cultivating direct understanding.</data><data key="node_lat" /><data key="node_lon" /></node><node id="YOL_PRA_0004"><data key="node_label">Illusory Body</data><data key="node_category">Underpinning</data><data key="node_degree">8</data><data key="node_presetTags">kagyu</data><data key="node_description">Practice in Six Yogas of Naropa.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0027"><data key="node_label">Impermanence</data><data key="node_category">Underpinning</data><data key="node_degree">5</data><data key="node_presetTags">kagyu; nyingma</data><data key="node_description">Contemplation of change and mortality used to cut attachment and energize practice.</data><data key="node_lat" /><data key="node_lon" /></node><node id="YOL_PRA_0005"><data key="node_label">Insight meditation / Vipashyana</data><data key="node_category">Underpinning</data><data key="node_degree">6</data><data key="node_presetTags" /><data key="node_description">Insight/analytical meditation.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0029"><data key="node_label">Karma and its Result</data><data key="node_category">Underpinning</data><data key="node_degree">4</data><data key="node_presetTags">kagyu; nyingma</data><data key="node_description">Ethical causality by which wholesome and unwholesome actions ripen into corresponding results.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0011"><data key="node_label">Karmamudra</data><data key="node_category">Underpinning</data><data key="node_degree">0</data><data key="node_presetTags" /><data key="node_description">Tantric sexual or imaginal union practice mentioned in six-dharma contexts.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0005"><data key="node_label">Lamdre / Path and Result</data><data key="node_category">Underpinning</data><data key="node_degree">8</data><data key="node_presetTags" /><data key="node_description">Distinctive Sakya contemplative system.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0004"><data key="node_label">Lamrim / Stages of the Path</data><data key="node_category">Underpinning</data><data key="node_degree">12</data><data key="node_presetTags">nyingma</data><data key="node_description">Structured path presentation central in the Geluk tradition.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0030"><data key="node_label">Loving-Kindness and Compassion</data><data key="node_category">Underpinning</data><data key="node_degree">7</data><data key="node_presetTags">kagyu; nyingma</data><data key="node_description">Cultivation of boundless loving-kindness and compassion as antidotes to aversion and bases for bodhicitta.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0010"><data key="node_label">Lucid dreaming</data><data key="node_category">Underpinning</data><data key="node_degree">2</data><data key="node_presetTags">kagyu</data><data key="node_description">Conscious awareness within the dream state.</data><data key="node_lat" /><data key="node_lon" /></node><node id="C_MAHAMUDRA"><data key="node_label">Mahamudra</data><data key="node_category">Underpinning</data><data key="node_degree">63</data><data key="node_presetTags">drukpa; kagyu</data><data key="node_description">Direct realization path of mind, basis/path/fruition, non-duality.</data><data key="node_lat" /><data key="node_lon" /></node><node id="YOL_PRA_0006"><data key="node_label">Mandala offerings</data><data key="node_category">Underpinning</data><data key="node_degree">0</data><data key="node_presetTags">kagyu</data><data key="node_description">Offering practice in preliminaries.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0007"><data key="node_label">Mantra recitation</data><data key="node_category">Underpinning</data><data key="node_degree">11</data><data key="node_presetTags">nyingma</data><data key="node_description">Vocal or mental repetition of sacred syllables or formulas.</data><data key="node_lat" /><data key="node_lon" /></node><node id="YOL_PRA_0007"><data key="node_label">Meditation</data><data key="node_category">Underpinning</data><data key="node_degree">97</data><data key="node_presetTags">kagyu</data><data key="node_description">General meditative practice across the book.</data><data key="node_lat" /><data key="node_lon" /></node><node id="YOL_PRD_0010"><data key="node_label">Non-meditation</data><data key="node_category">Underpinning</data><data key="node_degree">4</data><data key="node_presetTags">kagyu</data><data key="node_description">Advanced Mahamudra phase.</data><data key="node_lat" /><data key="node_lon" /></node><node id="C_MANTRA"><data key="node_label">Om mani padme hum</data><data key="node_category">Underpinning</data><data key="node_degree">6</data><data key="node_presetTags" /><data key="node_description">Six-syllable mantra woven into daily life.</data><data key="node_lat" /><data key="node_lon" /></node><node id="YOL_PRD_0011"><data key="node_label">One taste</data><data key="node_category">Underpinning</data><data key="node_degree">5</data><data key="node_presetTags">kagyu</data><data key="node_description">Advanced Mahamudra phase.</data><data key="node_lat" /><data key="node_lon" /></node><node id="YOL_PRD_0012"><data key="node_label">Path meditation</data><data key="node_category">Underpinning</data><data key="node_degree">2</data><data key="node_presetTags" /><data key="node_description">Path-oriented practice toward realization.</data><data key="node_lat" /><data key="node_lon" /></node><node id="C_PATH_LIBERATION"><data key="node_label">Path of Liberation</data><data key="node_category">Underpinning</data><data key="node_degree">0</data><data key="node_presetTags">kagyu</data><data key="node_description">Mind-taming / Mahamudra / yoga without form.</data><data key="node_lat" /><data key="node_lon" /></node><node id="C_PATH_MEANS"><data key="node_label">Path of Means</data><data key="node_category">Underpinning</data><data key="node_degree">0</data><data key="node_presetTags" /><data key="node_description">Prana-oriented tantric yoga path.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0034"><data key="node_label">Perfect Buddhahood</data><data key="node_category">Underpinning</data><data key="node_degree">3</data><data key="node_presetTags">kagyu</data><data key="node_description">Full awakening as the fruition of the path, including the kayas and enlightened activity.</data><data key="node_lat" /><data key="node_lon" /></node><node id="YOL_PRA_0012"><data key="node_label">Phowa / Transference of Consciousness</data><data key="node_category">Underpinning</data><data key="node_degree">8</data><data key="node_presetTags">kagyu</data><data key="node_description">Transference of consciousness practice.</data><data key="node_lat" /><data key="node_lon" /></node><node id="C_PILGRIMAGE"><data key="node_label">Pilgrimage</data><data key="node_category">Underpinning</data><data key="node_degree">21</data><data key="node_presetTags" /><data key="node_description">External pilgrimage to Tibet, India, Triloknath, Lahul, etc.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0009"><data key="node_label">Pranayama / breathing techniques</data><data key="node_category">Underpinning</data><data key="node_degree">5</data><data key="node_presetTags">kagyu</data><data key="node_description">Breath regulation practices integrated into subtle-body yogas.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0025"><data key="node_label">Precious Human Life</data><data key="node_category">Underpinning</data><data key="node_degree">2</data><data key="node_presetTags">kagyu; nyingma</data><data key="node_description">Human rebirth endowed with leisure and opportunity as the working basis for the path.</data><data key="node_lat" /><data key="node_lon" /></node><node id="YOL_PRA_0008"><data key="node_label">Preliminaries / Ngondro</data><data key="node_category">Underpinning</data><data key="node_degree">11</data><data key="node_presetTags" /><data key="node_description">Prostrations, refuge, mandalas and purification practices.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0002"><data key="node_label">Preliminary practices / Ngondro</data><data key="node_category">Underpinning</data><data key="node_degree">8</data><data key="node_presetTags">kagyu</data><data key="node_description">Preparatory tantric practices preceding advanced training.</data><data key="node_lat" /><data key="node_lon" /></node><node id="YOL_PRA_0009"><data key="node_label">Prostrations</data><data key="node_category">Underpinning</data><data key="node_degree">8</data><data key="node_presetTags" /><data key="node_description">Physical/devotional preliminary practice.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0031"><data key="node_label">Refuge / Three Jewels</data><data key="node_category">Underpinning</data><data key="node_degree">5</data><data key="node_presetTags">kagyu; nyingma</data><data key="node_description">Taking refuge in Buddha, Dharma, and Sangha as the gateway and ongoing basis of Buddhist practice.</data><data key="node_lat" /><data key="node_lon" /></node><node id="YOL_PRA_0010"><data key="node_label">Refuge formula</data><data key="node_category">Underpinning</data><data key="node_degree">10</data><data key="node_presetTags" /><data key="node_description">Formula of taking refuge.</data><data key="node_lat" /><data key="node_lon" /></node><node id="C_RETREAT"><data key="node_label">Retreat / ri-khrod / solitude</data><data key="node_category">Underpinning</data><data key="node_degree">26</data><data key="node_presetTags">kagyu; nyingma</data><data key="node_description">Hermitage life and solitary practice.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0015"><data key="node_label">Six Perfections / Paramitas</data><data key="node_category">Underpinning</data><data key="node_degree">14</data><data key="node_presetTags">kagyu</data><data key="node_description">Core Mahayana trainings of giving, morality, forbearance, striving, meditation, and insight.</data><data key="node_lat" /><data key="node_lon" /></node><node id="YOL_PRA_0011"><data key="node_label">Six Yogas of Naropa</data><data key="node_category">Underpinning</data><data key="node_degree">12</data><data key="node_presetTags">drukpa; kagyu; nyingma</data><data key="node_description">Tumo, Dream Yoga, Illusory Body, Clear Light, Bardo, Phowa.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0026"><data key="node_label">Spiritual Master</data><data key="node_category">Underpinning</data><data key="node_degree">4</data><data key="node_presetTags">kagyu; nyingma</data><data key="node_description">Qualified teacher whose guidance is indispensable on the path and must be approached with devotion and discernment.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0028"><data key="node_label">Suffering of Samsara</data><data key="node_category">Underpinning</data><data key="node_degree">3</data><data key="node_presetTags">kagyu; nyingma</data><data key="node_description">Examination of the pervasive, changing, and painful dimensions of cyclic existence in all six realms.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0036"><data key="node_label">Tantric Vows / Samaya</data><data key="node_category">Underpinning</data><data key="node_degree">6</data><data key="node_presetTags">kagyu</data><data key="node_description">Commitments of the awareness holder that protect and transform body, speech, and mind within Secret Mantra practice.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0033"><data key="node_label">Ten Bodhisattva Bhumis</data><data key="node_category">Underpinning</data><data key="node_degree">6</data><data key="node_presetTags">kagyu</data><data key="node_description">Ten bodhisattva grounds traversed from initial realization of emptiness to the threshold of buddhahood.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0006"><data key="node_label">Terma revelation</data><data key="node_category">Underpinning</data><data key="node_degree">4</data><data key="node_presetTags">nyingma</data><data key="node_description">Nyingma treasure revelation and treasure-revealer practice.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0035"><data key="node_label">Three Vows</data><data key="node_category">Underpinning</data><data key="node_degree">6</data><data key="node_presetTags">kagyu</data><data key="node_description">Integrated Buddhist ethics of personal liberation, bodhisattva commitments, and tantric pledges, sharply differentiated in Sakya Pandita's 'Three Codes'.</data><data key="node_lat" /><data key="node_lon" /></node><node id="YOL_PRA_0013"><data key="node_label">Tummo / Inner Heat</data><data key="node_category">Underpinning</data><data key="node_degree">10</data><data key="node_presetTags">kagyu</data><data key="node_description">Psychophysical heat practice in Six Yogas.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0008"><data key="node_label">Visualization</data><data key="node_category">Underpinning</data><data key="node_degree">8</data><data key="node_presetTags">kagyu</data><data key="node_description">Guided imaginal practice central to tantric meditation.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0018"><data key="node_label">Kalachakra</data><data key="node_category">Underpinning</data><data key="node_degree">4</data><data key="node_presetTags">kagyu</data><data key="node_description">Tantric cycle associated with cosmology, mantra, and subtle-body practice.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0017"><data key="node_label">Vajrasattva / Hundred-Syllable Practice</data><data key="node_category">Underpinning</data><data key="node_degree">2</data><data key="node_presetTags">kagyu</data><data key="node_description">Purificatory practice of Vajrasattva and recitation of the hundred syllables.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0019"><data key="node_label">Hevajra</data><data key="node_category">Underpinning</data><data key="node_degree">5</data><data key="node_presetTags">kagyu</data><data key="node_description">Principal yidam of Marpa and major tantric deity cycle in the Kagyu transmission.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0020"><data key="node_label">Vajravarahi</data><data key="node_category">Underpinning</data><data key="node_degree">6</data><data key="node_presetTags">kagyu</data><data key="node_description">Tantric deity/practice associated with Marpa’s line and shrine at Phamthing.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0037"><data key="node_label">Cittamatra / Mind-Only School</data><data key="node_category">Underpinning</data><data key="node_degree">0</data><data key="node_presetTags" /><data key="node_description">First Mahayana philosophical stage in Khenpo Tsultrim Gyamtso’s progressive meditation sequence, stressing the emptiness of perceived-perceiver duality.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0038"><data key="node_label">Svatantrika Madhyamaka</data><data key="node_category">Underpinning</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Madhyamaka approach in the progressive meditation sequence that uses neither-one-nor-many analysis to negate true existence.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0039"><data key="node_label">Prasangika Madhyamaka</data><data key="node_category">Underpinning</data><data key="node_degree">7</data><data key="node_presetTags" /><data key="node_description">Consequentialist Madhyamaka approach that refrains from positing its own ultimate assertions and critiques true arising.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0040"><data key="node_label">Absence of Self in the Individual</data><data key="node_category">Underpinning</data><data key="node_degree">0</data><data key="node_presetTags" /><data key="node_description">Progressive meditation stage that analyzes the aggregates and refutes a truly existent self in the individual.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0041"><data key="node_label">Fivefold Path of Mahamudra</data><data key="node_category">Underpinning</data><data key="node_degree">4</data><data key="node_presetTags">kagyu</data><data key="node_description">Mahamudra practice sequence emphasized by Phagmodrupa: bodhicitta, yidam deity, four kayas of guru yoga, mahamudra, and dedication.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0042"><data key="node_label">Six Cycles of Equal Taste</data><data key="node_category">Underpinning</data><data key="node_degree">3</data><data key="node_presetTags">drukpa; kagyu</data><data key="node_description">Distinctive Drukpa Kagyü contemplative cycle named by Schwerk as a central doctrinal and meditative system alongside Mahamudra and the Naropa yogas.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0043"><data key="node_label">Nature of Mind</data><data key="node_category">Underpinning</data><data key="node_degree">9</data><data key="node_presetTags">nyingma</data><data key="node_description">Direct recognition of the mind’s empty-luminous condition emphasized in Longchenpa’s Great Perfection writings and in related Dzogchen exposition.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXT_PRA_0044"><data key="node_label">Dharmadhatu</data><data key="node_category">Underpinning</data><data key="node_degree">4</data><data key="node_presetTags">nyingma</data><data key="node_description">The all-pervasive field or realm of reality, treated in Longchenpa’s Treasury of the Dharmadhatu as the spacious matrix of luminous awareness.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_001"><data key="node_label">Marco Polo</data><data key="node_category">Explorer</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Book opens by noting that his records do not prove a visit to Ladakh.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_002"><data key="node_label">Diogo d'Almeira</data><data key="node_category">Explorer</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Presented as the first Westerner to visit Ladakh; reported a land of strange Christians and monk-like figures.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_003"><data key="node_label">Antonio de Andrade</data><data key="node_category">Explorer</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Reached Ladakh in May 1624; associated with attempts to reopen or establish Christian mission in Tibet.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_004"><data key="node_label">Francesco de Azevedo</data><data key="node_category">Explorer</data><data key="node_degree">5</data><data key="node_presetTags">kagyu</data><data key="node_description">Short stay in Ladakh; travel account is noted for description of King Senge Namgyal.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_005"><data key="node_label">Giovanni de Oliveiro</data><data key="node_category">Explorer</data><data key="node_degree">2</data><data key="node_presetTags" /><data key="node_description">Short Jesuit visit from Tsaparang into Ladakh.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_006"><data key="node_label">Ippolito Desideri</data><data key="node_category">Explorer</data><data key="node_degree">8</data><data key="node_presetTags" /><data key="node_description">Reached Leh on 26 June 1717 according to cited travel account tradition; stayed nearly eight weeks in Leh; described rope bridge, avalanche danger, snow-blindness, and called Ladakh the 'Second Tibet'.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_007"><data key="node_label">Manuel Freyre</data><data key="node_category">Explorer</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Travelled with Desideri; reached Leh; later abandoned the enterprise and preferred to return by Kashmir.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_008"><data key="node_label">Samuel van der Putte</data><data key="node_category">Explorer</data><data key="node_degree">2</data><data key="node_presetTags" /><data key="node_description">Said to have entered Tibet via Ladakh and continued to Lhasa.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_009"><data key="node_label">Captain Turner</data><data key="node_category">Explorer</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Noted sculptured stones and inscription walls on the route between Kashmir and Leh and near Leh.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_010"><data key="node_label">William Moorcroft</data><data key="node_category">Explorer</data><data key="node_degree">14</data><data key="node_presetTags" /><data key="node_description">Stayed in Ladakh for two years; explored Nubra, Zangskar and Dras; studied agriculture and plants; built one of the first systematic British accounts.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_011"><data key="node_label">George Trebeck</data><data key="node_category">Explorer</data><data key="node_degree">10</data><data key="node_presetTags" /><data key="node_description">Appears as Moorcroft's companion in the Himalayan provinces and Central Asia journey.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_012"><data key="node_label">James Baillie Fraser</data><data key="node_category">Explorer</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Described Leh, trade fairs, and trade links with Yarkand and other regions; emphasized commercial significance of Ladakh and Gartok.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_013"><data key="node_label">Alexander Csoma de Koros</data><data key="node_category">Explorer</data><data key="node_degree">10</data><data key="node_presetTags" /><data key="node_description">Lived in Zangskar, studied Tibetan with local scholars and monks, and began the work that made him a pioneer Tibetan scholar.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_014"><data key="node_label">Dr. Henderson</data><data key="node_category">Explorer</data><data key="node_degree">6</data><data key="node_presetTags" /><data key="node_description">Reached Leh disguised as a Muslim merchant; kindly treated by the Ladakhi ruler; likely one of the first Europeans to visit Skardu/Little Tibet.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_015"><data key="node_label">G.T. Vigne</data><data key="node_category">Explorer</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Travelled from Baltistan to Leh and on to the Nubra valley, then returned by the same route; also collected plant specimens.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_016"><data key="node_label">Falconer</data><data key="node_category">Explorer</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Visited Kashmir, Baltistan and Ladakh and came up to Dras, collecting plant species.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_017"><data key="node_label">Alexander Gerard</data><data key="node_category">Explorer</data><data key="node_degree">2</data><data key="node_presetTags" /><data key="node_description">Crossed from the Manali side and described the motion sensation on a willow bridge en route to Leh.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_018"><data key="node_label">Lieutenant Henry Strachey</data><data key="node_category">Explorer</data><data key="node_degree">6</data><data key="node_presetTags" /><data key="node_description">Entered Tibetan territory in 1846 and later served on the Tibet Boundary Commission, which operated out of Ladakh and Leh.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_019"><data key="node_label">Richard Strachey</data><data key="node_category">Explorer</data><data key="node_degree">6</data><data key="node_presetTags" /><data key="node_description">Travel records are used in the book to show Hanle and the route onward to Guge.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_020"><data key="node_label">Alexander Cunningham</data><data key="node_category">Explorer</data><data key="node_degree">6</data><data key="node_presetTags" /><data key="node_description">Collected and reconstructed Ladakhi historical data, trade statistics, and observations on people, houses and economy; his work became a foundational source for later scholars.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_021"><data key="node_label">Thomas Thomson</data><data key="node_category">Explorer</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Collected plant species from western Tibet through Ladakh to the Karakoram and sent important material to herbaria.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_022"><data key="node_label">Wilhelm Heyde</data><data key="node_category">Explorer</data><data key="node_degree">2</data><data key="node_presetTags" /><data key="node_description">Reached Leh in April 1855; described the town as standing on caravan routes with a large bazaar and fine old royal palace.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_023"><data key="node_label">Eduard Pagell</data><data key="node_category">Explorer</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Travelled with Heyde; part of the team that opened Moravian mission work in the western Himalaya and Leh.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_024"><data key="node_label">Schlagintweit brothers</data><data key="node_category">Explorer</data><data key="node_degree">2</data><data key="node_presetTags" /><data key="node_description">Spent about two years in Ladakh and collected plants carefully</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_025"><data key="node_label">Pierre Jaccard</data><data key="node_category">Explorer</data><data key="node_degree">2</data><data key="node_presetTags" /><data key="node_description">One of two Swiss travellers who commented on the difficulty of Ladakhi/Tibetan speech and vocabulary.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_026"><data key="node_label">Pierre Vittoz</data><data key="node_category">Explorer</data><data key="node_degree">2</data><data key="node_presetTags" /><data key="node_description">Travelled with Pierre Jaccard</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_027"><data key="node_label">G. Knight</data><data key="node_category">Explorer</data><data key="node_degree">8</data><data key="node_presetTags" /><data key="node_description">Described Ladakhi customs, women, head-dress, Leh as a 'city of the dead', Hemis monastery, Kargil festivities, polo and social life.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_028"><data key="node_label">T.G. Montgomerie</data><data key="node_category">Explorer</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Helped measure Karakoram peaks and reached Ladakh with a Tibetan/Lhasa caravan in 1865.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_029"><data key="node_label">G.W. Leitner</data><data key="node_category">Explorer</data><data key="node_degree">12</data><data key="node_presetTags" /><data key="node_description">Recorded sculptures near Dras, costumes in Kargil, the giant image at Mulbekh, Lamayuru monastery, and inscriptions at Khalatse.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_030"><data key="node_label">Robert Barkley Shaw</data><data key="node_category">Explorer</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Studied the Arghuns of Ladakh, customs duties and transport; set out from Leh for Yarkand in September 1868; later became British Joint-Commissioner at Leh.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_031"><data key="node_label">George Hayward</data><data key="node_category">Explorer</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Joined or paralleled the Yarkand/Kashgar exploration world around Leh and later surveyed routes leading to Leh on behalf of the Royal Geographical Society.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_032"><data key="node_label">J.L. Stewart</data><data key="node_category">Explorer</data><data key="node_degree">18</data><data key="node_presetTags" /><data key="node_description">Made botanical tours in Ladakh and later returned in 1912-13, collecting large numbers of plant species across high-altitude zones.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_033"><data key="node_label">Frederic Drew</data><data key="node_category">Explorer</data><data key="node_degree">16</data><data key="node_presetTags" /><data key="node_description">Produced one of the classic geographical accounts of the region, covering climate, settlement, economy, agriculture, social groups, houses and monasteries.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_034"><data key="node_label">Ferdinand Stoliczka</data><data key="node_category">Explorer</data><data key="node_degree">6</data><data key="node_presetTags" /><data key="node_description">Carried out essential studies in Ladakh and died near the Karakoram Pass in June 1874; later commemorated in Leh.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_035"><data key="node_label">Forsyth</data><data key="node_category">Explorer</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Visited Leh with colleagues during a mission while British authorities monitored frontier interests.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_036"><data key="node_label">Golden Trotter</data><data key="node_category">Explorer</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Named as part of the Forsyth-linked group visiting Leh.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_037"><data key="node_label">Henderson (Forsyth mission)</data><data key="node_category">Explorer</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Mentioned together with Hume as a member of the Forsyth mission who helped publish a plant list from Ladakh and Yarkand.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_038"><data key="node_label">Hume</data><data key="node_category">Explorer</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Mentioned with Henderson as connected to the list of 412 plants collected in Ladakh and Yarkand.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_039"><data key="node_label">Jonson</data><data key="node_category">Explorer</data><data key="node_degree">2</data><data key="node_presetTags" /><data key="node_description">Climbed mountain summits around Leh from 1871 to 1883.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_040"><data key="node_label">Mr. and Mrs. Ujifarvy</data><data key="node_category">Explorer</data><data key="node_degree">2</data><data key="node_presetTags" /><data key="node_description">Travelled to Ladakh via the Karakoram.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_041"><data key="node_label">Francis Younghusband</data><data key="node_category">Explorer</data><data key="node_degree">11</data><data key="node_presetTags" /><data key="node_description">Reached Leh in July 1889; repeatedly used Ladakh routes in Great Game frontier work and later Tibetan political missions.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_042"><data key="node_label">A.D. Carey</data><data key="node_category">Explorer</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Reached Leh in July 1885, then moved eastward through the Changchenmo valley; returned to Ladakh in 1887.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_043"><data key="node_label">Andrew Dalgleish</data><data key="node_category">Explorer</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Accompanied Carey eastward from Leh toward Changchenmo.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_044"><data key="node_label">Isabella Bishop</data><data key="node_category">Explorer</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Travelled to Leh privately via Zojila with three servants.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_045"><data key="node_label">E.F. Knight</data><data key="node_category">Explorer</data><data key="node_degree">2</data><data key="node_presetTags" /><data key="node_description">Visited Leh and left a vignette of chhang, devils' dances and the bazaar atmosphere.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_046"><data key="node_label">Martin Conway</data><data key="node_category">Explorer</data><data key="node_degree">6</data><data key="node_presetTags" /><data key="node_description">Led a sizeable surveying party up the Indus to Leh and brought an artist and climbers into the Karakoram context.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_047"><data key="node_label">Dutreuil de Rhins</data><data key="node_category">Explorer</data><data key="node_degree">6</data><data key="node_presetTags" /><data key="node_description">Travelled via Keria Oasis, the Karakoram and Leh.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_048"><data key="node_label">Fernand Grenard</data><data key="node_category">Explorer</data><data key="node_degree">6</data><data key="node_presetTags" /><data key="node_description">Travelled with Dutreuil de Rhins via the Karakoram and Leh.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_049"><data key="node_label">C.B. Clark</data><data key="node_category">Explorer</data><data key="node_degree">2</data><data key="node_presetTags" /><data key="node_description">Credited with contributing to knowledge of Gilgit, Skardu and the Karakoram, though not much is said to be known from Ladakh proper.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_050"><data key="node_label">J.F. Duthie</data><data key="node_category">Explorer</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Crossed the Zojila in July 1893, visited Dras and the Deosai plains, then returned to Kashmir.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_051"><data key="node_label">Dr. Weber</data><data key="node_category">Explorer</data><data key="node_degree">2</data><data key="node_presetTags" /><data key="node_description">Responsible for meteorological observations and the post office at Leh</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_052"><data key="node_label">S.H. Ribbach</data><data key="node_category">Explorer</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Made a sustained study of Ladakhi culture, education, custom and ceremony over many years.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_053"><data key="node_label">A.H. Francke</data><data key="node_category">Explorer</data><data key="node_degree">12</data><data key="node_presetTags" /><data key="node_description">Produced foundational work on Ladakh and Indian Tibet; surveyed Buddhist Dard areas and major routes into Ladakh.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_054"><data key="node_label">Malcolm</data><data key="node_category">Explorer</data><data key="node_degree">2</data><data key="node_presetTags" /><data key="node_description">Mentioned alongside Weber as surveying Ladakh in 1899.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_055"><data key="node_label">Sven Hedin</data><data key="node_category">Explorer</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Visited Ladakh twice; described Leh as the last important place before Tibet, the Moravian mission, and the graves of Stoliczka and Dalgleish.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_056"><data key="node_label">Littledale</data><data key="node_category">Explorer</data><data key="node_degree">2</data><data key="node_presetTags" /><data key="node_description">Passed over Ladakh after an extensive trans-Central Asian and Tibetan journey.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_057"><data key="node_label">Fletcher</data><data key="node_category">Explorer</data><data key="node_degree">2</data><data key="node_presetTags" /><data key="node_description">Companion in the journey that eventually crossed Ladakh.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_058"><data key="node_label">Bullock Workman</data><data key="node_category">Explorer</data><data key="node_degree">8</data><data key="node_presetTags" /><data key="node_description">Reached Leh with Fanny Bullock Workman and pursued extensive climbing and observation in the greater Ladakh-Karakoram area.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_059"><data key="node_label">Fanny Bullock Workman</data><data key="node_category">Explorer</data><data key="node_degree">8</data><data key="node_presetTags" /><data key="node_description">Travelled and climbed with Dr. Bullock Workman and became one of the most visible women explorers of the Himalayan world in the book.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_060"><data key="node_label">Deasy</data><data key="node_category">Explorer</data><data key="node_degree">2</data><data key="node_presetTags" /><data key="node_description">Came to Ladakh in 1900 and later published Tibet and Chinese Turkistan as the record of three years' explorations.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_060A"><data key="node_label">Ransdel</data><data key="node_category">Explorer</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Came to Leh via Khotan in 1888-90, but the book says nothing further is known about his Ladakh travel.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_060B"><data key="node_label">Bower</data><data key="node_category">Explorer</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Travelled to Ladakh in 1891 with Dr. Thorold and attempted a northwest-to-southeast crossing into Tibet from northern Ladakh.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_060C"><data key="node_label">Dr. Thorold</data><data key="node_category">Explorer</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Travelled with Bower in the 1891 Ladakh-Tibet attempt.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_060D"><data key="node_label">Dr. Karl Max</data><data key="node_category">Explorer</data><data key="node_degree">2</data><data key="node_presetTags" /><data key="node_description">Ran a mission hospital at Leh and is described as the first fully trained missionary doctor there.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_061"><data key="node_label">A. Reeve Heber</data><data key="node_category">Explorer</data><data key="node_degree">18</data><data key="node_presetTags" /><data key="node_description">Gave detailed descriptions of Leh bazaar, Lamayuru, Dard/Brogpa communities, birds, Korzok/Changthang and village life.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_062"><data key="node_label">Kathleen M. Heber</data><data key="node_category">Explorer</data><data key="node_degree">18</data><data key="node_presetTags" /><data key="node_description">Co-authored the observations on Leh market, Brogpas, Korzok, dress, religion and village economy.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_063"><data key="node_label">Rawling</data><data key="node_category">Explorer</data><data key="node_degree">6</data><data key="node_presetTags" /><data key="node_description">Entered the Changchenmo valley in 1902 and began a second journey from Leh in May 1903.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_064"><data key="node_label">Meebold</data><data key="node_category">Explorer</data><data key="node_degree">12</data><data key="node_presetTags" /><data key="node_description">Came from Kashmir in 1905, explored Suru and Kangri region including the route to Da, visited Leh and crossed Khardongla.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_065"><data key="node_label">Tsuyoshi Hino</data><data key="node_category">Explorer</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Presented as the first Japanese to have visited Ladakh.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_066"><data key="node_label">Filippi de Filippi</data><data key="node_category">Explorer</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Walked up to Leh along the frozen Indus through deep gorges with a large expedition train.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_067"><data key="node_label">Major M.L.A. Gompertz ('Ganpat')</data><data key="node_category">Explorer</data><data key="node_degree">8</data><data key="node_presetTags" /><data key="node_description">Travelled extensively for over six months, describing people, roads, religion, settlement, food and economy in detail.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_068"><data key="node_label">Giuseppe Tucci</data><data key="node_category">Explorer</data><data key="node_degree">5</data><data key="node_presetTags">kagyu</data><data key="node_description">Visited Ladakh repeatedly as part of wider Tibetan Buddhist research and reflected on crossing into Tibetan cultural worlds.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_069"><data key="node_label">William O. Douglas</data><data key="node_category">Explorer</data><data key="node_degree">2</data><data key="node_presetTags" /><data key="node_description">After Indian independence, penetrated into Ladakh and travelled as a passionate mountaineer.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_070"><data key="node_label">Marco Pallis</data><data key="node_category">Explorer</data><data key="node_degree">46</data><data key="node_presetTags">drukpa; kagyu</data><data key="node_description">Left one of the most vivid literary accounts in the volume, covering routes, settlements, monasteries, architecture, women, food and ritual life.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_071"><data key="node_label">H.R.H. Peter, Prince of Greece and Denmark</data><data key="node_category">Explorer</data><data key="node_degree">6</data><data key="node_presetTags" /><data key="node_description">Documented population, social groups, marriage, divorce, kinship, houses, food, tax and polyandry in Ladakh.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_072"><data key="node_label">Walter Asboe</data><data key="node_category">Explorer</data><data key="node_degree">2</data><data key="node_presetTags" /><data key="node_description">Started a professional school at Leh and organized the Gospel Inn catering to travellers on the Central Asia trade route.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_073"><data key="node_label">F.A. Peter</data><data key="node_category">Explorer</data><data key="node_degree">2</data><data key="node_presetTags" /><data key="node_description">Proposed reclaiming new land near Spituk using an Indus water channel.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_074"><data key="node_label">David Snellgrove</data><data key="node_category">Explorer</data><data key="node_degree">11</data><data key="node_presetTags">drukpa; kagyu</data><data key="node_description">Visited soon after Ladakh was opened to foreigners and co-published The Cultural Heritage of Ladakh.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_075"><data key="node_label">Tadeusz Skorupski</data><data key="node_category">Explorer</data><data key="node_degree">2</data><data key="node_presetTags" /><data key="node_description">Visited with David Snellgrove and co-published The Cultural Heritage of Ladakh.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_076"><data key="node_label">Tokan D. Sumi</data><data key="node_category">Explorer</data><data key="node_degree">2</data><data key="node_presetTags" /><data key="node_description">Visited after the opening to foreigners and co-authored Ladakh: The Moonland.</data><data key="node_lat" /><data key="node_lon" /></node><node id="EXP_077"><data key="node_label">Masato Oki</data><data key="node_category">Explorer</data><data key="node_degree">2</data><data key="node_presetTags" /><data key="node_description">Visited after the opening to foreigners and co-authored Ladakh: The Moonland.</data><data key="node_lat" /><data key="node_lon" /></node><edge id="e1" source="P_ASANGA" target="EXT_PRA_0014"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">kagyu</data></edge><edge id="e2" source="P_ASANGA" target="EXT_PRA_0015"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">kagyu</data></edge><edge id="e3" source="P_ASANGA" target="EXT_PRA_0027"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">kagyu; nyingma</data></edge><edge id="e4" source="P_ASANGA" target="T_YOGACARA"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags" /></edge><edge id="e5" source="P_ASANGA" target="EXT_PRA_0024"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">kagyu; nyingma</data></edge><edge id="e6" source="P_ATISA" target="EXT_TRA_0001"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">kagyu; nyingma</data></edge><edge id="e7" source="P_ATISA" target="T_KAGYU"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e8" source="P_ATISA" target="T_VAJRA"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">kagyu</data></edge><edge id="e9" source="P_ATISA" target="YOL_TRA_0005"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">kagyu</data></edge><edge id="e10" source="P_ATISA" target="YOL_TRA_0006"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">kagyu</data></edge><edge id="e11" source="P_ATISA" target="YOL_TRA_0012"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">kagyu</data></edge><edge id="e12" source="P_ATISA" target="EXT_PRA_0014"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">kagyu</data></edge><edge id="e13" source="P_ATISA" target="EXT_PRA_0016"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">kagyu</data></edge><edge id="e14" source="P_ATISA" target="EXT_PER_0024"><data key="edge_type">meeting_visit</data><data key="edge_label">meeting / visit</data><data key="edge_date">before 1042</data><data key="edge_outcome">Received bodhisattva teachings from Serlingpa, journeyed to Tibet, and taught disciples such as Dromtönpa while establishing Kadampa-oriented instruction.</data><data key="edge_presetTags">kagyu</data></edge><edge id="e15" source="P_ATISA" target="PL_TIBET"><data key="edge_type">meeting_visit</data><data key="edge_label">meeting / visit</data><data key="edge_date">1042–1054</data><data key="edge_outcome">Received bodhisattva teachings from Serlingpa, journeyed to Tibet, and taught disciples such as Dromtönpa while establishing Kadampa-oriented instruction.</data><data key="edge_presetTags">kagyu; nyingma</data></edge><edge id="e16" source="P_ATISA" target="EXT_PER_0025"><data key="edge_type">meeting_visit</data><data key="edge_label">meeting / visit</data><data key="edge_date">11th century</data><data key="edge_outcome">Received bodhisattva teachings from Serlingpa, journeyed to Tibet, and taught disciples such as Dromtönpa while establishing Kadampa-oriented instruction.</data><data key="edge_presetTags">kagyu</data></edge><edge id="e17" source="EXT_PER_0003" target="C_MANTRA"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags" /></edge><edge id="e18" source="EXT_PER_0003" target="EXT_PRA_0007"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">nyingma</data></edge><edge id="e19" source="EXT_PER_0003" target="EXT_TRA_0001"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">nyingma</data></edge><edge id="e20" source="EXT_PER_0003" target="T_VAJRA"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">kagyu</data></edge><edge id="e21" source="EXT_PER_0003" target="YOL_PRA_0007"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">kagyu</data></edge><edge id="e22" source="EXT_PER_0003" target="YOL_TRA_0012"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags" /></edge><edge id="e23" source="YOL_PER_0004" target="C_MAHAMUDRA"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e24" source="YOL_PER_0004" target="T_DRUKPA"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e25" source="YOL_PER_0004" target="T_KAGYU"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e26" source="YOL_PER_0004" target="YOL_PRA_0007"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e27" source="YOL_PER_0005" target="C_MAHAMUDRA"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">drukpa; kagyu; nyingma</data></edge><edge id="e28" source="YOL_PER_0005" target="YOL_PRA_0007"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">kagyu; nyingma</data></edge><edge id="e29" source="YOL_PER_0005" target="YOL_PRD_0006"><data key="edge_type">underpinning</data><dat