an</data><data key="node_category">Place</data><data key="node_degree">17</data><data key="node_presetTags">drukpa; kagyu; nyingma</data><data key="node_description">Region central to the Bhutanese Drukpa branch and to the seventeenth-century split between northern (Tibetan/Ladakhi) and southern Drukpa formations.</data><data key="node_lat">27.5142</data><data key="node_lon">90.4336</data></node><node id="ENT_PLA_EX_048"><data key="node_label">Bod Karbu</data><data key="node_category">Place</data><data key="node_degree">2</data><data key="node_presetTags" /><data key="node_description">Place referenced in Famous Western Explorers to Ladakh.</data><data key="node_lat">34.41</data><data key="node_lon">76.06</data></node><node id="EXT_PLA_0004"><data key="node_label">Bodhgaya / Bodh Gaya</data><data key="node_category">Place</data><data key="node_degree">4</data><data key="node_presetTags" /><data key="node_description">Site of the Buddha's awakening.</data><data key="node_lat">24.695</data><data key="node_lon">84.991</data></node><node id="PL_CHAMBA"><data key="node_label">Chamba / Triloknath region</data><data key="node_category">Place</data><data key="node_degree">1</data><data key="node_presetTags" /><data key="node_description">Pilgrimage/missionary site where Brahmins receive teaching.</data><data key="node_lat">32.55</data><data key="node_lon">76.02</data></node><node id="ENT_PLA_EX_026"><data key="node_label">Changchenmo Valley</data><data key="node_category">Place</data><data key="node_degree">6</data><data key="node_presetTags" /><data key="node_description">Place referenced in Famous Western Explorers to Ladakh.</data><data key="node_lat">34.43</data><data key="node_lon">78.44</data></node><node id="EXT_PLA_0012"><data key="node_label">Changthang</data><data key="node_category">Place</data><data key="node_degree">3</data><data key="node_presetTags">drukpa; kagyu</data><data key="node_description">High plateau region of eastern Ladakh.</data><data key="node_l