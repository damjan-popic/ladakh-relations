ey="edge_outcome" /><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e79" source="P_GAMPOPA" target="EXT_PRA_0024"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">drukpa; kagyu; nyingma</data></edge><edge id="e80" source="P_GAMPOPA" target="C_BODHICITTA"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">drukpa; kagyu; nyingma</data></edge><edge id="e81" source="P_GAMPOPA" target="EXT_PRA_0014"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e82" source="P_GAMPOPA" target="EXT_PRA_0015"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e83" source="P_GAMPOPA" target="EXT_PRA_0032"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e84" source="P_GAMPOPA" target="EXT_PRA_0033"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e85" source="P_GAMPOPA" target="EXT_PRA_0034"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e86" source="P_GAMPOPA" target="EXT_PRA_0041"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e87" source="P_GAMPOPA" target="P_MILAREPA"><data key="edge_type">meeting_visit</data><data key="edge_label">meeting / visit</data><data key="edge_date">12th century</data><data key="edge_outcome">On his way to meet Milarepa, Gampopa fell ill in Dingri, supplicated the lama, and eventually met him at Tashi Gang</data><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e88" source="P_GAMPOPA" target="YOL_PLA_0009"><data key="edge_type">meeting_visit</data><data key="edge_label">meeting / visit</data><data key="edge_date">12th century journey west</data><data key="edge_outcome">after training with Milarepa he went to Dagla Gampo, where he taught and institutionalized the fused Kadampa-Mahamudra lineage.</data><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e89" source="P_GAMPOPA" target="EXT_PLA_0020"><data key="edge_type">meeting_visit</data><data key="edge_label">meeting / visit</data><data key="edge_date">after training with Milarepa</data><data key="edge_outcome">On his way to meet Milarepa, Gampopa fell ill in Dingri, supplicated the lama, and eventually met him at Tashi Gang; after training with Milarepa he went to Dagla Gampo, where he taught and institutionalized the fused Kadampa-Mahamudra lineage.</data><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e90" source="YOL_PER_0022" target="C_MAHAMUDRA"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e91" source="YOL_PER_0022" target="T_DRUKPA"><data key="edge_type">underpinning</data><data key="edge_label">associated with</data><data key="edge_date" /><data key="edge_outcome" /><data key="edge_presetTags">drukpa; kagyu</data></edge><edge id="e92" source="YOL_PER_0022" target="T_KAGYU"><data key="edge_type">underpinning</data><data